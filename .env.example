# OELP environment variables — copy to .env.local for development.

# vocab-cat-test FastAPI backend (default: docker-compose service on localhost).
# Production: replace with Cloud Run URL.
NEXT_PUBLIC_VOCAB_CAT_TEST_URL=http://localhost:8000

# Supabase (Phase 1 auth + events table). Phase 1 dogfooding can leave these unset
# and skip auth; required for analytics-events.md logging.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
